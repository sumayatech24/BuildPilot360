# BuildPilot360 API configuration
APP_NAME=BuildPilot360 API
ENVIRONMENT=development

# Database. Default is local SQLite. For Postgres use:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/buildpilot360
DATABASE_URL=sqlite:///./buildpilot360.db

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# CORS (comma separated). Includes Vite dev server + Electron file origin.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,app://.

# Provider-neutral AI routing. Leave empty to use the built-in deterministic stub analyzer.
AI_PROVIDER=stub
AI_API_KEY=
AI_MODEL=

# Seed bootstrap owner
SEED_OWNER_EMAIL=owner@buildpilot360.dev
SEED_OWNER_PASSWORD=ChangeMe123!
SEED_TENANT_NAME=BuildPilot360
